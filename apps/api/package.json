{
  "name": "@promptshield/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "npm run build -w @promptshield/core && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build -w @promptshield/core && vitest run",
    "seed": "tsx src/seed.ts",
    "worker": "tsx src/worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/client-sesv2": "^3.1019.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@promptshield/core": "file:../../packages/core",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "nodemailer": "^7.0.5",
    "postgres": "^3.4.7",
    "redis": "^5.9.0",
    "stripe": "^18.5.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11"
  }
}
